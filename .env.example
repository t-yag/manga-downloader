# コミックシーモア ログイン認証情報
CMOA_EMAIL=your-email@example.com
CMOA_PASSWORD=your-password

# テスト用タイトル情報（Cookie検証に使用 - 購入済みのタイトルを指定）
# 注: 購入済みの任意のタイトルIDと巻番号を指定してください
TEST_TITLE_ID=99473
TEST_VOLUME=10

# Chrome実行パス（オプション: 未指定の場合はpuppeteerが自動検出）
# macOS例: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows例: C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_EXECUTABLE_PATH=
