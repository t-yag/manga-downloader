# Server
PORT=3000
HOST=0.0.0.0

# Database
# DB_DIR=./data/db

# Chrome/Puppeteer
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# Browser login (Puppeteer GUI)
# Set to "true" to enable browser-based login (requires display).
# Only works when frontend is accessed via web browser (disabled on iOS/Android).
# Default: false (disabled) — suitable for Docker/headless environments.
ENABLE_BROWSER_LOGIN=true
